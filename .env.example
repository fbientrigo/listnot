# pucv-aq-qc environment configuration (EXAMPLE)
# Copy to .env and fill in. NEVER commit a real .env or a real secret.

# Deployment profile: local | server | cloud
PUCV_AQ_ENV=local

# Database connection. SQLite for local; PostgreSQL for server/cloud.
# local:  sqlite:///data/pucv.db
# server: postgresql+psycopg://pucv:PASSWORD@db:5432/pucv
DATABASE_URL=sqlite:///data/pucv.db

# HMAC identity secret (>= 32 random bytes, base64). Generate with:
#   python scripts/generate_secret.py
# NEVER commit a real value. Left empty here on purpose.
PUCV_ID_SECRET_V1=

# Which secret version to use for newly derived IDs.
PUCV_ACTIVE_KEY_VERSION=v1

# Small-group suppression threshold for statistical outputs.
PUCV_MIN_GROUP_SIZE=10

# Export/report storage backend: local | s3 | gcs | azure
PUCV_STORAGE_BACKEND=local

# Demo mode enables /demo endpoints and demo secret auto-generation.
PUCV_DEMO_MODE=true
